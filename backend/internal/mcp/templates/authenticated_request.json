{
  "id": "authenticated_request",
  "name": "Authenticated API Call",
  "description": "Makes an API call with a Bearer token from stored credentials.",
  "category": "HTTP",
  "inputs": [
    {
      "key": "API_BASE_URL",
      "label": "API Base URL",
      "description": "The base URL of your API (e.g. https://api.example.com)",
      "type": "url",
      "target": "env",
      "placeholder": "https://api.example.com",
      "required": true
    },
    {
      "key": "api_token",
      "label": "API Key / Bearer Token",
      "description": "Your authentication token — will be stored encrypted",
      "type": "secret",
      "target": "credential",
      "credential_field": "token",
      "placeholder": "sk-...",
      "required": true
    }
  ],
  "flow": {
    "schema_version": "1.0",
    "name": "authenticated_request",
    "description": "Makes an authenticated API call using a stored credential",
    "input_schema": {
      "path": { "type": "string", "required": true, "description": "API path (e.g. /users/123)" }
    },
    "nodes": [
      {
        "id": "fetch",
        "type": "http_request",
        "config": {
          "url": "{{env.API_BASE_URL}}{{input.path}}",
          "method": "GET",
          "headers": { "Authorization": "Bearer {{credentials.api_token.token}}" }
        },
        "outputs": { "status": { "type": "number" }, "body": { "type": "any" } }
      },
      {
        "id": "result",
        "type": "json_transform",
        "config": {
          "mapping": {
            "data": "{{nodes.fetch.outputs.body}}",
            "status": "{{nodes.fetch.outputs.status}}"
          }
        },
        "outputs": { "result": { "type": "object" } }
      }
    ],
    "edges": [{ "from": "fetch", "to": "result" }],
    "output": "{{nodes.result.outputs.result}}",
    "_ui": {
      "positions": {
        "fetch": { "x": 250, "y": 100 },
        "result": { "x": 250, "y": 280 }
      }
    }
  }
}

# ─── Core ───────────────────────────────────────────────────────────────────
# Auto-generated on first docker compose up — change before exposing publicly
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=noodle
POSTGRES_PASSWORD=noodle
POSTGRES_DB=noodle
DATABASE_URL=postgres://noodle:noodle@postgres:5432/noodle?sslmode=disable

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── AI Provider (pick one) ──────────────────────────────────────────────────
# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Ollama (local — set base URL instead)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Which provider to use: anthropic | openai | ollama
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
